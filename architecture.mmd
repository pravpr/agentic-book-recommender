flowchart TD

    subgraph DataPrep[Data Preparation & Embeddings]
        A[Goodbooks-10k<br/>books.csv + ratings.csv]
        B[prepare_goodbooks_subset.py<br/>→ books_subset.csv, ratings_subset.csv]
        C[build_book_embeddings.py<br/>SentenceTransformer all-MiniLM-L6-v2<br/>→ book_embeddings.npy]
        A --> B --> C
    end

    subgraph AgentRuntime[Agent Runtime]
        U[User Input<br/>"Book you like"]
        F[find_book_index_by_title]
        T1[tool_recommend_books<br/>(cosine_similarity over embeddings)]
        R[reflect_and_adjust<br/>filter low ratings + author diversity]
        OUT[Final Recommendations]
        FBQ[User Feedback y/n]
        T2[log_feedback<br/>→ feedback.csv]
    end

    subgraph Evaluation[Evaluation]
        E[evaluate_agent.py<br/>Reads feedback.csv<br/>→ metrics]
    end

    C --> AgentRuntime
    U --> F --> T1 --> R --> OUT --> FBQ --> T2 --> E
